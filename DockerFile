FROM continuumio/miniconda3

WORKDIR /app

RUN conda install -c conda-forge python=3.11 dlib git -y

COPY requirements.txt .

# Install face_recognition_models from GitHub explicitly
RUN pip install --no-cache-dir git+https://github.com/ageitgey/face_recognition_models

RUN pip install --no-cache-dir -r requirements.txt

COPY . .

EXPOSE 10000

CMD ["gunicorn", "-w", "2", "-b", "0.0.0.0:10000", "app:app"]